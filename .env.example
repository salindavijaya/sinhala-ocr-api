# ─────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=sinhala-ocr-api

# ─────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-64-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────────
# PostgreSQL (Cloud SQL in production)
# ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sinhala_ocr
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────
# Redis (Cloud Memorystore in production)
# ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─────────────────────────────────────────────────
# Google Cloud Platform
# ─────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_FILE=./gcp-service-account.json
# Leave GCP_KEY_FILE empty when running on GCP (uses ADC)

GCS_BUCKET_NAME=sinhala-ocr-uploads
GCS_OUTPUT_BUCKET_NAME=sinhala-ocr-outputs
# Signed URL expiry in seconds (default 72hrs = 259200)
GCS_SIGNED_URL_EXPIRY=259200

# ─────────────────────────────────────────────────
# File upload limits
# ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/tiff,application/pdf

# ─────────────────────────────────────────────────
# Job / TTL settings
# ─────────────────────────────────────────────────
# How long (hours) to keep completed job files before purge
JOB_TTL_HOURS=72
# Bull queue concurrency (workers processing simultaneously)
QUEUE_CONCURRENCY=3
# Max job retries on failure
QUEUE_MAX_RETRIES=2

# ─────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────
# Requests per window per IP (general)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Transcription endpoint specific
TRANSCRIBE_RATE_LIMIT_WINDOW_MS=3600000
TRANSCRIBE_RATE_LIMIT_MAX=20

# ─────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# ─────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
