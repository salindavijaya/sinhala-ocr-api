{
  "name": "sinhala-ocr-api",
  "version": "1.0.0",
  "description": "Production API for transcribing Sinhala handwritten documents to Unicode text",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/transcription.worker.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "migrate": "node migrations/run.js",
    "migrate:rollback": "node migrations/rollback.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/vision": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 65
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/migrations/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/workers/transcription.worker.js",
      "!src/services/ocr.service.js",
      "!src/services/document.service.js",
      "!src/services/queue.service.js",
      "!src/config/database.js",
      "!src/config/redis.js",
      "!src/utils/logger.js",
      "!src/middleware/auth.js",
      "!src/middleware/rateLimiter.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
